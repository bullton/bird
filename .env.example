# 服务端
NODE_ENV=production
PORT=3000

# JWT 密钥（请改为随机 32+ 字符串）
JWT_SECRET=please-change-me-to-a-random-32-byte-string

# 数据目录
BIRDLOG_DATA_DIR=./data
BIRDLOG_DB=./data/birdlog.db
BIRDLOG_PHOTOS_DIR=./data/photos

# 前端构建产物目录（部署时由 build 产出）
BIRDLOG_STATIC_DIR=./client/dist

# AI 默认值（可在管理后台覆盖）
AI_BASE_URL=https://api.minimaxi.com
AI_MODEL=MiniMax-M3
AI_TIMEOUT_MS=30000

# 后台任务 worker 数
TASK_WORKERS=3

# 上传限制（字节）
UPLOAD_MAX_BYTES=31457280

# 站点信息
SITE_NAME=家庭鸟类图鉴